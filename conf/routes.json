{
  "routes": [
    {
      "id": "1",
      "name": "data-api",
      "uri": "/api/*",
      "upstream": {
        "type": "roundrobin",
        "nodes": {
          "data-api:8000": 1
        }
      }
    },
    {
      "id": "2",
      "name": "analytics-api",
      "uri": "/analytics/*",
      "upstream": {
        "type": "roundrobin",
        "nodes": {
          "analytics-api:8001": 1
        }
      }
    }
  ]
}
